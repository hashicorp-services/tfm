# tfm environment variables
# Copy this file to .env and populate with your values.
# All keys map directly to .tfm.hcl config file keys (uppercase, no prefix).
# tfm uses Viper's AutomaticEnv() — env vars override config file values.
#
# Usage with a shell:
#   set -a
#   . ./.env
#   set +a
#   tfm list workspaces
#
# Usage with direnv (.envrc):
#   dotenv .env

# ============================================================
# SOURCE — Terraform Enterprise or HCP Terraform (source org)
# ============================================================

# Hostname of the source TFE/TFC instance (no https://)
# For HCP Terraform use: app.terraform.io
SRC_TFE_HOSTNAME=app.terraform.io

# Source organisation name
SRC_TFE_ORG=my-source-org

# API token for the source organisation (user or team token)
SRC_TFE_TOKEN=<source-api-token>

# ============================================================
# DESTINATION — HCP Terraform or Terraform Enterprise (dest org)
# ============================================================

# Hostname of the destination TFE/TFC instance (no https://)
# For HCP Terraform use: app.terraform.io
DST_TFC_HOSTNAME=app.terraform.io

# Destination organisation name
DST_TFC_ORG=my-destination-org

# API token for the destination organisation (user or team token)
DST_TFC_TOKEN=<destination-api-token>

# Optional: default destination project ID for workspace copy operations
# DST_TFC_PROJECT_ID=prj-xxxxxxxxxxxx

# ============================================================
# VCS INTEGRATION (required for core/clone migration flows)
# ============================================================

# VCS provider type: "github" or "gitlab"
# VCS_TYPE=github

# VCS provider ID in the destination TFC/TFE org (from: tfm list vcs)
# VCS_PROVIDER_ID=vcs-xxxxxxxxxxxx

# ============================================================
# GITHUB (required when VCS_TYPE=github or using core commands)
# ============================================================

# GitHub personal access token.
# Use the least privilege required: for classic PATs, `repo` is typically
# sufficient for private repo clone/push operations; avoid broad scopes like
# `admin:org` unless you have a separate, specific administrative need.
# Fine-grained PATs are preferred: grant access only to the required
# repositories, with repository contents read/write permissions as needed.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# GitHub organisation to clone repos from / into
# GITHUB_ORGANIZATION=my-github-org

# GitHub username (used when pushing cloned repos)
# GITHUB_USERNAME=my-github-user

# ============================================================
# GITLAB (required when VCS_TYPE=gitlab or using core commands)
# ============================================================

# GitLab personal access token
# GITLAB_TOKEN=glpat-xxxxxxxxxxxx

# GitLab group name
# GITLAB_GROUP=my-gitlab-group

# GitLab username
# GITLAB_USERNAME=my-gitlab-user

# ============================================================
# CORE MIGRATION (tfm core clone / upload-states / link-vcs)
# ============================================================

# Local path where repos will be cloned
# CLONE_REPOS_PATH=/tmp/tfm-repos

# Comma-separated list of repo names to clone (overrides config file list)
# REPOS_TO_CLONE=repo-one,repo-two,repo-three

# Git commit author details for state migration commits
# COMMIT_AUTHOR_NAME="TFM Migration Bot"
# COMMIT_AUTHOR_EMAIL=tfm@example.com
# COMMIT_MESSAGE="chore: migrate state via tfm"
